name: ECONOMIC_DASHBOARD_SEMANTIC
tables:
  - name: ECONOMIC_DASHBOARD_LIVE
    description: The table contains records of key macroeconomic indicators tracked over time. Each record corresponds to a specific date and includes measures related to consumer prices, unemployment, and mortgage rates.
    base_table:
      database: ECON_AGENT_DB
      schema: ANALYTICS
      table: ECONOMIC_DASHBOARD_LIVE
    time_dimensions:
      - name: DATE
        description: The date associated with each economic data record.
        expr: DATE
        data_type: DATE
        sample_values:
          - '2005-04-14'
          - '2020-11-05'
          - '2008-05-22'
    facts:
      - name: CPI
        description: The Consumer Price Index (CPI) value used to measure inflation and changes in purchasing power over time.
        expr: CPI
        data_type: FLOAT
        sample_values:
          - '22.4'
          - '326.588'
      - name: MORTGAGE_RATE_30Y
        description: The 30-year fixed mortgage interest rate.
        expr: MORTGAGE_RATE_30Y
        data_type: FLOAT
        sample_values:
          - '0.0605'
          - '0.0661'
          - '0.1365'
      - name: UNEMPLOYMENT_RATE_30Y
        description: The 30-year unemployment rate expressed as a decimal proportion of the labor force.
        expr: UNEMPLOYMENT_RATE_30Y
        data_type: FLOAT
        sample_values:
          - '0.066'
          - '0.075'
          - '0.074'
    unique_keys:
      - columns:
          - DATE
