This is our interpretation of your question:

What was the average unemployment rate in November 2025?

Physical query
WITH __economic_dashboard_live AS (
  SELECT
    date,
    unemployment_rate_30y
  FROM
    ECON_AGENT_DB.ANALYTICS.ECONOMIC_DASHBOARD_LIVE
)
SELECT
  DATE_TRUNC('MONTH', date) AS month,
  AVG(unemployment_rate_30y) AS avg_unemployment_rate
FROM
  __economic_dashboard_live
WHERE
  DATE_TRUNC('MONTH', date) = '2025-11-01'
GROUP BY
  DATE_TRUNC('MONTH', date)
ORDER BY
  month DESC NULLS LAST -- Generated by Cortex Analyst (request_id: 98547cab-4f76-44ee-a61d-a056fdaffb81)
